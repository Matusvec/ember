# .env.example
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# ── ElevenLabs ──────────────────────────────────────────────────────────────
# Get your key from https://elevenlabs.io/app/speech-synthesis
ELEVENLABS_API_KEY=sk_your_key_here

# Create an agent at https://elevenlabs.io/app/conversational-ai
# The agent can have a placeholder prompt — voice/conversation.py overrides it at runtime.
ELEVENLABS_AGENT_ID=your_agent_id_here

# Optional: override the default Rachel voice with any ElevenLabs voice ID
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Picovoice (wake word) ────────────────────────────────────────────────────
# Free key from https://console.picovoice.ai
PICOVOICE_ACCESS_KEY=your_picovoice_key_here

# Built-in keyword to use (computer, jarvis, porcupine, hey siri, alexa, etc.)
# For a custom "Hey Axis" wake word: train at console.picovoice.ai and set the path below
AXIS_WAKE_KEYWORD=computer
# AXIS_WAKE_KEYWORD_PATH=/path/to/hey-axis_en_linux_v3_0_0.ppn

# ── Voice pipeline behaviour ─────────────────────────────────────────────────
# Set to 1 to enable continuous screen narration (reads screen changes aloud)
AXIS_CONTINUOUS_NARRATION=0

# How often (seconds) the narrator polls for screen changes
# AXIS_NARRATION_INTERVAL=2.5

# ── TTS cache ────────────────────────────────────────────────────────────────
# Optional: override the default TTS audio cache location
# AXIS_CACHE_DIR=/tmp/axis_tts_cache
